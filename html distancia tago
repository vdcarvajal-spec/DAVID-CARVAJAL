<!DOCTYPE html>

<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sensor Ultrasonico ESP32</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      background-color: #0f172a;
      color: white;
    }

    h1 {
      margin-top: 40px;
      color: #38bdf8;
    }

    .card {
      margin: 40px auto;
      padding: 20px;
      background: #1e293b;
      border-radius: 12px;
      width: 250px;
    }

    .valor {
      font-size: 40px;
      margin-top: 10px;
    }
  </style>

</head>

<body>

  <h1>Distancia del Sensor</h1>

  <div class="card">
    <p>Distancia actual:</p>
    <div id="distancia" class="valor">-- cm</div>
  </div>

  <script>
    const TOKEN = "1381e14e-6295-4bbb-be18-aea49cce4ff8"; // 🔥 PON AQUÍ TU TOKEN

    async function obtenerDatos() {
      try {
        const response = await fetch("https://api.tago.io/data?variable=distancia&query=last_value", {
          headers: {
            "Device-Token": TOKEN
          }
        });

        const data = await response.json();

        if (data.result.length > 0) {
          document.getElementById("distancia").innerText =
            data.result[0].value + " cm";
        }

      } catch (error) {
        console.error("Error:", error);
      }
    }

    setInterval(obtenerDatos, 3000);
    obtenerDatos();
  </script>

</body>
</html>
