<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Car Sensor</title>
  <style>
    :root {
      --bg-color: #0f172a;
      --card-bg: #1e293b;
      --accent: #38bdf8;
      --car-pos: 0px; /* Dinámico */
    }

    body {
      font-family: 'Segoe UI', sans-serif;
      background-color: var(--bg-color);
      color: white;
      margin: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      overflow: hidden;
    }

    .container {
      width: 90%;
      max-width: 500px;
      text-align: center;
    }

    .distance-badge {
      background: var(--accent);
      color: #000;
      padding: 10px 20px;
      border-radius: 50px;
      font-weight: bold;
      font-size: 1.5rem;
      margin-bottom: 20px;
      display: inline-block;
      box-shadow: 0 0 20px rgba(56, 189, 248, 0.4);
    }

    /* Escenario de la carretera */
    .road {
      position: relative;
      width: 100%;
      height: 150px;
      background: #334155;
      border-radius: 20px;
      border-bottom: 8px solid #1e293b;
      display: flex;
      align-items: center;
      overflow: hidden;
      margin: 30px 0;
    }

    .line {
      position: absolute;
      width: 100%;
      height: 2px;
      border-top: 2px dashed rgba(255,255,255,0.2);
      top: 50%;
    }

    /* El Vehículo */
    .car {
      position: absolute;
      font-size: 50px;
      left: 20px;
      transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      transform: translateX(var(--car-pos));
      z-index: 2;
    }

    /* El Obstáculo (Pared) */
    .wall {
      position: absolute;
      right: 0;
      width: 15px;
      height: 100%;
      background: #ef4444;
      box-shadow: -5px 0 15px rgba(239, 68, 68, 0.5);
    }

    .info-card {
      background: var(--card-bg);
      padding: 20px;
      border-radius: 15px;
      border: 1px solid #334155;
    }

    .status {
      font-size: 0.8rem;
      color: #94a3b8;
      margin-top: 10px;
    }
  </style>
</head>
<body>

  <div class="container">
    <h1>Sensor de Reversa</h1>
    
    <div id="distancia-txt" class="distance-badge">Cargando...</div>

    <div class="road">
      <div class="line"></div>
      <div id="car" class="car">🚗</div>
      <div class="wall"></div>
    </div>

    <div class="info-card">
      <p>Estado del sistema: <strong id="safe-status" style="color: #22c55e;">OK</strong></p>
      <div id="update-time" class="status">Esperando datos de TagoIO...</div>
    </div>
  </div>

  <script>
    const TOKEN = "1381e14e-6295-4bbb-be18-aea49cce4ff8"; 
    const carElement = document.getElementById("car");
    const roadWidth = document.querySelector(".road").offsetWidth - 100; // Margen para no chocar

    async function actualizarDashboard() {
      try {
        const response = await fetch("https://api.tago.io/data?variable=distancia&qty=1", {
          headers: { "Device-Token": TOKEN }
        });
        const data = await response.json();

        if (data.status && data.result.length > 0) {
          const distancia = parseFloat(data.result[0].value);
          
          // Actualizar texto
          document.getElementById("distancia-txt").innerText = distancia.toFixed(1) + " cm";
          document.getElementById("update-time").innerText = "Última lectura: " + new Date().toLocaleTimeString();

          // Lógica de movimiento del coche
          // Supongamos que 50cm es "lejos" (0px) y 2cm es "choque" (roadWidth px)
          let maxDist = 50; 
          let minDist = 2;
          
          // Invertimos el valor para que a menor distancia, mayor sea el movimiento (X)
          let calculoPos = ((maxDist - distancia) / (maxDist - minDist)) * roadWidth;
          
          // Limitar rango
          if (calculoPos < 0) calculoPos = 0;
          if (calculoPos > roadWidth) calculoPos = roadWidth;

          // Mover el coche visualmente
          document.documentElement.style.setProperty('--car-pos', calculoPos + "px");

          // Cambiar alertas según distancia
          const statusTxt = document.getElementById("safe-status");
          if (distancia < 10) {
            statusTxt.innerText = "¡PELIGRO!";
            statusTxt.style.color = "#ef4444";
            carElement.innerText = "💥"; // Cambia a explosión si choca
          } else if (distancia < 20) {
            statusTxt.innerText = "CUIDADO";
            statusTxt.style.color = "#f59e0b";
            carElement.innerText = "🚗";
          } else {
            statusTxt.innerText = "SEGURO";
            statusTxt.style.color = "#22c55e";
            carElement.innerText = "🚗";
          }
        }
      } catch (error) {
        console.error("Error:", error);
        document.getElementById("update-time").innerText = "Error de conexión";
      }
    }

    setInterval(actualizarDashboard, 2000); // Actualiza cada 2 segundos
    actualizarDashboard();
  </script>
</body>
</html>
